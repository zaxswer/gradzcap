    bytecblock "gzc_asa_id" 0x73 "scholarship_amount"
    txn ApplicationID
    bnz main_after_if_else@2
    // IntegrityExam.py:25
    // self.gzc_asa_id         = UInt64(0)
    bytec_0 // "gzc_asa_id"
    intc_0 // 0
    app_global_put
    // IntegrityExam.py:26
    // self.scholarship_amount = UInt64(0)
    bytec_2 // "scholarship_amount"
    intc_0 // 0
    app_global_put

main_after_if_else@2:
    // IntegrityExam.py:19
    // class IntegrityExam(ARC4Contract):
    txn OnCompletion
    !
    assert
    txn ApplicationID
    bz main_create_NoOp@12
    pushbytess 0xdf54e8aa 0x11133418 0xe6945e17 0x6f703a51 0x0dd11896 0x9dbb4a76 // method "opt_in_to_asset(uint64)void", method "claim_demo_tokens()void", method "stake_and_start(axfer)void", method "record_cheat(address)void", method "complete_exam(address,uint64)void", method "admin_withdraw(uint64)void"
