    match opt_in_to_asset claim_demo_tokens stake_and_start record_cheat complete_exam admin_withdraw
    err

main_create_NoOp@12:
    // IntegrityExam.py:19
    // class IntegrityExam(ARC4Contract):
    pushbytes 0xa03b81d2 // method "create_application(uint64)void"
    txna ApplicationArgs 0
